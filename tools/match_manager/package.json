{
  "name": "boa-match-manager",
  "version": "1.0.0",
  "description": "Terminal match manager for Boa engine approval runs.",
  "type": "module",
  "bin": {
    "match-manager": "dist/cli.js",
    "boa-match-manager": "dist/cli.js",
    "boa-ablate": "dist/ablation.js"
  },
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.tsx",
    "web": "./run-web.sh",
    "server:dev": "tsx src/server.ts",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "ablate": "tsx src/ablation.ts",
    "check": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.6.2",
    "chess.js": "^1.4.0",
    "commander": "^15.0.0",
    "ink": "^7.0.6",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
